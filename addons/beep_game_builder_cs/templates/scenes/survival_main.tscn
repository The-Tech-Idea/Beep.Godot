LevelContainerPath = NodePath("../LevelContainer")

[node name="Temperature" type="Node" parent="."]
script = ExtResource("5_temperature")

[node name="HUD" type="CanvasLayer" parent="."]

[node name="WeatherForecast" type="Control" parent="HUD"]
anchors_preset = 1
anchor_right = 1.0
anchor_bottom = 1.0
offset_top = 100
offset_right = -640
offset_bottom = -600
script = ExtResource("7_forecast")

[node name="TopLeft" type="MarginContainer" parent="HUD"]
anchors_preset = 1
anchor_right = 1.0
offset_right = 40.0
offset_bottom = 40.0
grow_vertical = 0
theme_override_constants/margin_left = 12
theme_override_constants/margin_top = 12

[node name="StatsVBox" type="VBoxContainer" parent="HUD/TopLeft"]
theme_override_constants/separation = 4

[node name="HealthLabel" type="Label" parent="HUD/TopLeft/StatsVBox"]
text = "Health: 100 %"

[node name="HungerLabel" type="Label" parent="HUD/TopLeft/StatsVBox"]
text = "Hunger: 75 %"

[node name="GameFlow" type="Node" parent="."]
