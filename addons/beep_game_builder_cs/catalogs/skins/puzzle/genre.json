{
  "id": "puzzle",
  "display_name": "Puzzle",
  "icon": "🧩",
  "description": "Match-3 / grid puzzle",
  "default_theme": "candy",
  "default_geometry": "puzzle",
  "themes": ["candy", "cartoon", "modern", "sea", "japan"],
  "main_scene": "puzzle_main.tscn",
  "scenes": ["level_map.tscn", "pre_level.tscn", "level_complete.tscn", "level_failed.tscn"],
  "tuning": {
    "grid_width": 8,
    "grid_height": 8,
    "target_score": 1000
  },
  "nav_wiring": {
    "main_menu.tscn":        { "GameScene": "res://scenes/main/puzzle_main.tscn", "Settings": "res://scenes/ui/settings_menu.tscn" },
    "pause_menu.tscn":       { "Settings": "res://scenes/ui/settings_menu.tscn", "MainMenu": "res://scenes/ui/main_menu.tscn" },
    "game_over.tscn":        { "MainMenu": "res://scenes/ui/main_menu.tscn", "GameScene": "res://scenes/main/puzzle_main.tscn" },
    "level_map.tscn":        { "MainMenu": "res://scenes/ui/main_menu.tscn", "Settings": "res://scenes/ui/settings_menu.tscn", "PreLevel": "res://scenes/ui/puzzle/pre_level.tscn" },
    "pre_level.tscn":        { "LevelSelect": "res://scenes/ui/puzzle/level_map.tscn", "GameScene": "res://scenes/main/puzzle_main.tscn" },
    "level_complete.tscn":   { "LevelSelect": "res://scenes/ui/puzzle/level_map.tscn", "NextLevel": "res://scenes/ui/puzzle/pre_level.tscn", "GameScene": "res://scenes/main/puzzle_main.tscn" },
    "level_failed.tscn":     { "LevelSelect": "res://scenes/ui/puzzle/level_map.tscn", "GameScene": "res://scenes/main/puzzle_main.tscn" }
  }
}
