## Platformer enhancements: coyote time, jump buffer, ladder climbing
## Extends the platformer player with extra mechanics

# ──── Ladder ────
class_name Ladder
extends Area2D

@export var climb_speed: float = 150.0

var player_on_ladder: CharacterBody2D = null


func _ready() -> void:
	body_entered.connect(func(b): if b.is_in_group("player"): player_on_ladder = b)
	body_exited.connect(func(b): if b == player_on_ladder: player_on_ladder = null)


func _physics_process(_delta: float) -> void:
	if player_on_ladder == null: return
	var vertical = Input.get_axis("move_up", "move_down")
	if vertical != 0:
		player_on_ladder.velocity.y = vertical * climb_speed
		player_on_ladder.velocity.x = 0
		player_on_ladder.move_and_slide()


