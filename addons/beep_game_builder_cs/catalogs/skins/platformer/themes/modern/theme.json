    "accent_primary": "#4A8FD9FF", "accent_secondary": "#6BA3E3FF",
    "border_normal": "#FFFFFF00", "border_hover": "#4A8FD94D", "border_focus": "#4A8FD9B3",
    "border_bevel_light": "#FFFFFF00", "border_bevel_dark": "#FFFFFF00",
    "shadow_color": "#00000038", "bg_panel": "#1F1F29F2", "bg_canvas": "#15151CFF",
