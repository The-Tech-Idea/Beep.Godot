{
  "id": "puzzle",
  "display_name": "Puzzle",
  "icon": "🧩",
  "description": "Match-3 / grid puzzle",
  "default_theme": "candy",
  "default_geometry": "puzzle",
  "themes": ["candy", "cartoon", "modern", "sea", "japan"],
  "main_scene": "puzzle_main.tscn",
  "scenes": ["level_map.tscn", "pre_level.tscn", "level_complete.tscn", "level_failed.tscn"],
  "tuning": {
    "grid_width": 8,
    "grid_height": 8,
    "target_score": 1000,
    "enable_weather": true,
    "default_weather": "Clear",
    "enable_day_night": false,
    "enable_seasons": true,
    "default_season": "Spring",
    "days_per_season": 7,
    "enable_temperature": false,
    "ambient_temperature": 20,
    "enable_forecast": true,
    "forecast_days": 7
  }
}
