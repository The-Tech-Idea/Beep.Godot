{
  "id": "puzzle",
  "display_name": "Puzzle",
  "icon": "🧩",
  "description": "Match-3 / grid puzzle",
  "default_theme": "candy",
  "default_geometry": "puzzle",
  "themes": ["candy", "cartoon", "modern", "sea", "japan"],
  "main_scene": "puzzle_main.tscn",
  "scenes": ["level_map.tscn", "pre_level.tscn", "level_complete.tscn", "level_failed.tscn"],
  "nav_wiring": {
    "LevelMapPath": "level_map.tscn",
    "PreLevelPath": "pre_level.tscn",
    "LevelCompletePath": "level_complete.tscn",
    "LevelFailedPath": "level_failed.tscn"
  },
  "tuning": {
    "grid_width": 8,
    "grid_height": 8,
    "target_score": 1000,
    "enable_weather": false,
    "default_weather": "Clear",
    "enable_day_night": false,
    "enable_seasons": false,
    "default_season": "Spring",
    "days_per_season": 7,
    "enable_temperature": false,
    "ambient_temperature": 20,
    "enable_forecast": false,
    "forecast_days": 7,
    "enable_save_load": true,
    "max_save_slots": 5,
    "autosave_enabled": true,
    "autosave_interval_seconds": 300
  }
}
