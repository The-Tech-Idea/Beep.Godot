{
  "id": "platformer",
  "display_name": "Platformer",
  "icon": "🎮",
  "description": "Side-scrolling jump & run",
  "default_theme": "cartoon",
  "default_geometry": "platformer",
  "themes": ["cartoon", "modern", "retro80s", "pixel8bit", "nature"],
  "main_scene": "platformer_main.tscn",
  "scenes": ["level_select.tscn", "level_results.tscn"],
  "tuning": {
    "gravity": 980,
    "jump_velocity": -400,
    "move_speed": 200
  },
  "nav_wiring": {
    "main_menu.tscn":      { "GameScene": "res://scenes/main/platformer_main.tscn", "Settings": "res://scenes/ui/settings_menu.tscn" },
    "pause_menu.tscn":     { "Settings": "res://scenes/ui/settings_menu.tscn", "MainMenu": "res://scenes/ui/main_menu.tscn" },
    "game_over.tscn":      { "MainMenu": "res://scenes/ui/main_menu.tscn", "GameScene": "res://scenes/main/platformer_main.tscn" },
    "level_select.tscn":   { "MainMenu": "res://scenes/ui/main_menu.tscn", "GameScene": "res://scenes/main/platformer_main.tscn", "NextLevel": "res://scenes/ui/platformer/level_results.tscn" },
    "level_results.tscn":  { "LevelSelect": "res://scenes/ui/platformer/level_select.tscn", "GameScene": "res://scenes/main/platformer_main.tscn" }
  }
}
