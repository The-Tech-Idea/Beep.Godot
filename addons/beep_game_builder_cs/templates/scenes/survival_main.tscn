[node name="SurvivalMain" type="Node2D"]

[node name="Atmosphere" parent="." instance=ExtResource("atmos_scene")]

[node name="LevelContainer" type="Node2D" parent="."]

[node name="LevelLoader" type="Node" parent="."]
script = ExtResource("10_loader")
