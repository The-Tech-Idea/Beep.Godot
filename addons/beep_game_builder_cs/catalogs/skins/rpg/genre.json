      "GameScene": "res://scenes/main/rpg_main.tscn"
    },
    "character.tscn": {
      "MainMenu": "res://scenes/ui/main_menu.tscn",
      "GameScene": "res://scenes/main/rpg_main.tscn"
    },
    "quests.tscn": {
      "MainMenu": "res://scenes/ui/main_menu.tscn",
      "GameScene": "res://scenes/main/rpg_main.tscn"
