{
  "id": "cardgame",
  "display_name": "Card Game",
  "icon": "\ud83c\udccf",
  "description": "Deck building, card battles, collection and rewards",
  "default_theme": "velvet",
  "default_geometry": "cardgame",
  "themes": [
    "velvet",
    "arcane",
    "casino",
    "paper",
    "royal"
  ],
  "main_scene": "cardgame_main.tscn",
  "scenes": [
    "deck_builder.tscn",
    "card_battle.tscn",
    "collection.tscn"
  ],
  "tuning": {
    "hand_limit": 10,
    "card_hover_scale": 1.12,
    "card_fan_angle": 18
  },
  "nav_wiring": {
    "main_menu.tscn": {
      "GameScene": "res://scenes/main/cardgame_main.tscn",
      "Settings": "res://scenes/ui/settings_menu.tscn"
    },
    "pause_menu.tscn": {
      "Settings": "res://scenes/ui/settings_menu.tscn",
      "MainMenu": "res://scenes/ui/main_menu.tscn"
    },
    "game_over.tscn": {
      "MainMenu": "res://scenes/ui/main_menu.tscn",
      "GameScene": "res://scenes/main/cardgame_main.tscn"
    },
    "deck_builder.tscn": {
      "MainMenu": "res://scenes/ui/main_menu.tscn",
      "GameScene": "res://scenes/main/cardgame_main.tscn"
    },
    "card_battle.tscn": {
      "MainMenu": "res://scenes/ui/main_menu.tscn",
      "GameScene": "res://scenes/main/cardgame_main.tscn"
    },
    "collection.tscn": {
      "MainMenu": "res://scenes/ui/main_menu.tscn",
      "GameScene": "res://scenes/main/cardgame_main.tscn"
    }
  }
}
