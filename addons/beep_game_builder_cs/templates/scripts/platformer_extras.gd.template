# ──── Screen Shake ────
class_name ScreenShake
extends Node

static var instance: ScreenShake
var camera: Camera2D
var shake_intensity: float = 0.0
var shake_decay: float = 0.0
var rng = RandomNumberGenerator.new()


func _ready() -> void:
	instance = self
	camera = get_viewport().get_camera_2d()


static func shake(intensity: float = 10.0, duration: float = 0.3) -> void:
	if instance == null: return
	instance.shake_intensity = intensity
	instance.shake_decay = intensity / duration


func _process(delta: float) -> void:
	if shake_intensity <= 0 or camera == null: return
	shake_intensity -= shake_decay * delta
	if shake_intensity <= 0:
		shake_intensity = 0
		camera.offset = Vector2.ZERO
		return
	camera.offset = Vector2(
		rng.randf_range(-shake_intensity, shake_intensity),
		rng.randf_range(-shake_intensity, shake_intensity)
	)


# ──── Speech Bubble ────
class_name SpeechBubble
extends Node2D

@export var bubble_duration: float = 3.0
@export var follow_target: Node2D = null
@export var bubble_offset: Vector2 = Vector2(0, -50)

@onready var label: Label = $Label
@onready var bg: NinePatchRect = $NinePatchRect


func _ready() -> void:
	visible = false


func say(text: String, duration: float = -1) -> void:
	label.text = text
	visible = true
	var t = duration if duration > 0 else bubble_duration
	await get_tree().create_timer(t).timeout
	visible = false


func _process(_delta: float) -> void:
	if follow_target and is_instance_valid(follow_target):
		global_position = follow_target.global_position + bubble_offset
