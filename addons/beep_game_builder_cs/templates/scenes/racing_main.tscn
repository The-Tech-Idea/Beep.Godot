[gd_scene load_steps=7 format=3]

[ext_resource type="Script" path="res://addons/beep_game_builder_cs/ecs/GameFlowComponent.cs" id="1_flow"]
[ext_resource type="PackedScene" path="res://addons/beep_game_builder_cs/templates/scenes/atmosphere.tscn" id="atmos_scene"]
[ext_resource type="Script" path="res://addons/beep_game_builder_cs/ecs/ui/WeatherForecastUI.cs" id="6_forecast"]
[ext_resource type="Script" path="res://addons/beep_game_builder_cs/ecs/LevelLoaderComponent.cs" id="10_loader"]
[ext_resource type="PackedScene" path="res://addons/beep_game_builder_cs/templates/scenes/levels/racing/level_1.tscn" id="lvl_1"]
[ext_resource type="PackedScene" path="res://addons/beep_game_builder_cs/templates/scenes/levels/racing/level_2.tscn" id="lvl_2"]

[node name="RacingMain" type="Node2D"]

[node name="Atmosphere" parent="." instance=ExtResource("atmos_scene")]

[node name="LevelContainer" type="Node2D" parent="."]

[node name="LevelLoader" type="Node" parent="."]
script = ExtResource("10_loader")
Levels = Array[PackedScene]([ExtResource("lvl_1"), ExtResource("lvl_2")])
LevelContainerPath = NodePath("../LevelContainer")

[node name="HUD" type="CanvasLayer" parent="."]

[node name="WeatherForecast" type="Control" parent="HUD"]
anchors_preset = 1
anchor_right = 1.0
anchor_bottom = 1.0
offset_top = 100
offset_right = -640
offset_bottom = -600
script = ExtResource("6_forecast")

[node name="TopLeft" type="MarginContainer" parent="HUD"]
anchors_preset = 1
anchor_right = 1.0
offset_right = 40.0
offset_bottom = 40.0
grow_vertical = 0
theme_override_constants/margin_left = 12
theme_override_constants/margin_top = 12

[node name="StatsVBox" type="VBoxContainer" parent="HUD/TopLeft"]
theme_override_constants/separation = 4

[node name="SpeedLabel" type="Label" parent="HUD/TopLeft/StatsVBox"]
text = "Speed: 0 / 320 km/h"

[node name="LapLabel" type="Label" parent="HUD/TopLeft/StatsVBox"]
text = "Lap: 1 / 3"

[node name="GameFlow" type="Node" parent="."]
script = ExtResource("1_flow")
