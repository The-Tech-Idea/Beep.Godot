{
  "id": "modern",
  "display_name": "Modern",
  "category": "Modern",
  "description": "Clean minimal UI — soft shadow, rounded corners, neutral blue-grey surface, subtle transitions",
  "colors": {
    "surface_primary": "#2E2E3AFF", "surface_hover": "#3D3D4DFF", "surface_pressed": "#21212EFF", "surface_disabled": "#1A1A26FF",
