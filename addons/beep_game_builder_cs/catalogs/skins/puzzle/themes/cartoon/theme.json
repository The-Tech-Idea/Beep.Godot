    "accent_primary": "#FF6B36FF", "accent_secondary": "#FF8C59FF",
    "border_normal": "#2E1C00FF", "border_hover": "#000000FF", "border_focus": "#FF6B36FF",
    "border_bevel_light": "#FFFFFF00", "border_bevel_dark": "#FFFFFF00",
    "shadow_color": "#000000CC", "bg_panel": "#FFF3D6FF", "bg_canvas": "#FFE8BFFF",
